# Database
DATABASE_URL="file:./dev.db"
# To use Postgres in production: DATABASE_URL="postgresql://user:pass@host:5432/dateinindia"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Auth secrets (CHANGE IN PRODUCTION)
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="30d"

# Admin
ADMIN_SECRET_KEY="dev-admin-secret-change-me"

# Dev / mock mode toggles (set to "false" and supply real creds for production)
MOCK_OTP=true
MOCK_AADHAAR=true
MOCK_SELFIE=true
MOCK_PAYMENTS=true

# MSG91 (real SMS OTP) - optional, only used when MOCK_OTP=false
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# Setu / DigiLocker (real Aadhaar verification) - optional, only used when MOCK_AADHAAR=false
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=

# HyperVerge (real selfie liveness) - optional, only used when MOCK_SELFIE=false
HYPERVERGE_APP_ID=
HYPERVERGE_APP_KEY=

# Razorpay (real payments) - optional, only used when MOCK_PAYMENTS=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# OpenAI (optional - AI wingman / bio suggestions). If unset, simple fallback logic is used.
OPENAI_API_KEY=
